package EcuacionLineal;

public class EcuacionLineal1 {
    private double a;
    private double b;
    private double c;
    private double d;
    private double e;
    private double f;
    
    public EcuacionLineal1(double a, double b, double c, double d, double e, double f) {
        this.a = a;
        this.b = b;
        this.c = c;
        this.d = d;
        this.e = e;
        this.f = f;
    }

    public boolean tieneSolucion() {
        double determinante = a * d - b * c;
        return Math.abs(determinante) > 1e-10;
    }

    public double getX() {
        if (!tieneSolucion()) {
            throw new IllegalStateException("La ecuación no tiene solución");
        }
        double determinante = a * d - b * c;
        return (e * d - b * f) / determinante;
    }

    public double getY() {
        if (!tieneSolucion()) {
            throw new IllegalStateException("La ecuación no tiene solución");
        }
        double determinante = a * d - b * c;
        return (a * f - e * c) / determinante;
    }

    public double getA() { return a; }
    public double getB() { return b; }
    public double getC() { return c; }
    public double getD() { return d; }
    public double getE() { return e; }
    public double getF() { return f; }
}

